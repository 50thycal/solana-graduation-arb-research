# RPC
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Program IDs
PUMP_FUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
PUMPSWAP_PROGRAM_ID=pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA

# Collection Settings
OBSERVATION_DURATION_SECONDS=300
SNAPSHOT_INTERVAL_MS=1000
MAX_CONCURRENT_OBSERVATIONS=20

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_ENABLED=true

# Infrastructure
HEALTH_PORT=8080
DATA_DIR=./data
LOG_LEVEL=info

# "The Analyst" — LLM commentary stream on the /live-training page. ALL OPTIONAL.
# Without ANTHROPIC_API_KEY the stream still runs on its built-in line pool;
# set the key to upgrade to real Claude-generated roasts/praise.
# ANTHROPIC_API_KEY=sk-ant-...      # enables the live LLM commentary
# ROAST_MODEL=claude-opus-4-8       # model id (default claude-opus-4-8)
# ROAST_MIN_INTERVAL_MS=15000       # global cooldown between Claude calls (cost cap)

# Copy-trade wallet-intelligence (Option B, Phase 1) — ALL OPTIONAL.
# The CopytradeWorker is default-ON and needs no configuration; it reuses
# HELIUS_RPC_URL. These only override the conservative defaults.
# COPYTRADE_DISABLED=true        # turn the worker off entirely
# COPYTRADE_INTERVAL_MS=21600000 # scoring interval (default 6h)
# COPYTRADE_SCORE_BATCH=10       # wallets scored per tick
# COPYTRADE_MAX_SIGS=400         # signature history depth per wallet (RPC cost cap)
# COPYTRADE_RESTALE_SEC=86400    # re-score a wallet at most once per N seconds
