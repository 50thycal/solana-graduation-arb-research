      "action": "journal-upsert",
      "id": "v43-trailsl-15-7-1s",
      "strategy_id": "v43-trailsl-15-7-1s",
      "cohort_label": "v43",
      "hypothesis": "v43 SL-defense cohort on the v25-bot-excl-climbing universe (top5<=30 + dd>-25 + vel<200 + age>=60 + climbing_t30_t45; TP100/SL30/entry@T+60), all on pollIntervalSec=1 (the proven overshoot fix: v28-1s is the top monthly earner). This arm adds a profit-armed trailing SL (arm at +15%, trail 7% below HWM). Rationale: sl-precursor near-miss=0 means winners never approach the -30% stop, so the 33% SL rate is genuine pop-then-fade + straight dumpers. A trailing SL converts the pop-then-fade subset into profitable/shallow exits instead of letting them bleed to -30% (which realizes -43%). Tighter-static-SL is deliberately avoided: panel4 shows SL30 is EV-optimal and v27-sl20 has drop3 -1.29.",
      "prediction": {
        "target_net_sol": 1.5,
        "target_sol_per_mo": 3.75,
        "target_drop_top3": 0,
        "target_n": 100,
        "target_days": 14,
        "kill_criterion": "n>=50 and net_sol<-1"
      },
      "status": "OPEN"
    },
