      "action": "journal-upsert",
      "id": "v28-velmono-dev-1s-ttp",
      "strategy_id": "v28-velmono-dev-1s-ttp",
      "cohort_label": "v28",
      "hypothesis": "Mirror of v9shadow-velmono-dev (currently #1 by net SOL: +4.08 SOL, 21.46% avg, 11 TP / 14 SL / 13 TO on n=38) with TWO changes: pollIntervalSec=1 (1s poll instead of 5s) + trailingTpEnabled=true / dropPct=10. Hypothesis: 1s polling catches fast SL/TP transitions earlier — on a -50%-in-2s rug, current 5s polling fires SL at -50% (the price at the next poll), while 1s polling fires closer to the configured -30%. Estimated savings: ~10pp per SL fire on the fast-rug subset. Trailing TP=10% adds the right-tail capture on top.",
      "prediction": {
        "target_net_sol": 6.0,
        "target_sol_per_mo": 18,
        "target_drop_top3": 1.5,
        "target_n": 80,
        "target_days": 14,
        "kill_criterion": "n>=40 and net_sol<-1"
      },
      "status": "OPEN"
    },
