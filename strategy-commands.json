    {
      "action": "upsert",
      "id": "v4-sumabs-opt",
      "label": "v4 sumabs opt (100/30)",
      "enabled": true,
      "params": {
        "tradeSizeSol": 0.5,
        "maxConcurrentPositions": 1,
        "entryGateMinPctT30": 5,
        "entryGateMaxPctT30": 100,
        "maxHoldSeconds": 300,
        "slGapPenaltyPct": 20,
        "tpGapPenaltyPct": 10,
        "filters": [
          { "field": "bc_velocity_sol_per_min", "operator": "<", "value": 20, "label": "vel<20" },
          { "field": "top5_wallet_pct",         "operator": "<", "value": 10, "label": "top5<10%" },
          { "field": "sum_abs_returns_0_30",    "operator": "<", "value": 60, "label": "sum_abs<60" }
