    {
      "action": "journal-upsert",
      "id": "v35-vel2050-dev3",
      "strategy_id": "v35-vel2050-dev3",
      "cohort_label": "v35",
      "hypothesis": "Direct A/B vs the winning v9shadow-velmono-dev (vel 20-50 + mono>0.5 + dev>5%, +4.25 SOL on n=41). Tests whether LOW dev concentration outperforms HIGH dev in the same vel band. Prior dev<3% strategies all paired with slow velocity (vel<5) and never cleared 1 SOL. If dev<3% > dev>5% here, the high-dev result is a coincidence; if dev<3% < dev>5%, dev concentration is genuinely a positive signal in mid-vel - counter to conventional wisdom. Same TP/SL grid as parent (100/30) for clean apples-to-apples.",
      "prediction": {
        "target_net_sol": 1.5,
        "target_sol_per_mo": 3.75,
        "target_drop_top3": 0,
        "target_n": 100,
        "target_days": 14,
        "kill_criterion": "n>=50 and net_sol<-1"
      },
      "status": "OPEN"
    },
